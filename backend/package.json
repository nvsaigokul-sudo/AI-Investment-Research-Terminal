{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend service for AI Investment Research Agent",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node -e \"const fs = require('fs'); fs.mkdirSync('dist/db', { recursive: true }); fs.copyFileSync('src/db/schema.sql', 'dist/db/schema.sql');\"",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.1.1",
    "@langchain/langgraph": "^0.2.0",
    "ai-investment-research-agent": "file:..",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.4",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
